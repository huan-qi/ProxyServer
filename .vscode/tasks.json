{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "cmake: configure (Debug)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-S",
				".",
				"-B",
				"${workspaceFolder}/.build/Debug",
				"-G",
				"MinGW Makefiles",
				"-DVCPKG_TARGET_TRIPLET=x64-mingw-static",
				"-DCMAKE_BUILD_TYPE=Debug"
			]
		},
		{
			"label": "cmake: build (Debug)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"${workspaceFolder}/.build/Debug",
				"--config",
				"Debug"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "cmake: configure (Release)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-S",
				".",
				"-B",
				"${workspaceFolder}/.build/Release",
				"-G",
				"MinGW Makefiles",
				"-DVCPKG_TARGET_TRIPLET=x64-mingw-static",
				"-DCMAKE_BUILD_TYPE=Release"
			]
		},
		{
			"label": "cmake: build (Release)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"${workspaceFolder}/.build/Release",
				"--config",
				"Release"
			],
			"group": "build"
		},
		{
			"label": "build(Debug)",
			"dependsOn":[
				"cmake: configure (Debug)",
				"cmake: build (Debug)"
			],
			"dependsOrder": "sequence"
		},
		{
			"label": "build(Release)",
			"dependsOn":[
				"cmake: configure (Release)",
				"cmake: build (Release)"
			],
			"dependsOrder": "sequence"
		}
	]
}